{
  "version": 2,
    "outputDirectory": ".",
  "builds": [
    {
      "src": "public/index.php",
      "use": "vercel-php@0.8.0"
    },
    {
      "src": "api/index.php",
      "use": "vercel-php@0.8.0"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.php"
    }
  ]
}