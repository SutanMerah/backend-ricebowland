{
  "version": 2,
  "outputDirectory": ".",
  "functions": {
    "api/server.php": {
      "runtime": "vercel-php@0.8.0"
    }
  },
  "routes": [
    {
      "src": "/api",
      "dest": "/api/server.php"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/server.php"
    },
    {
      "src": "/(.*)",
      "dest": "/api/server.php"
    }
  ]
}