{
  "version": 2,
    "outputDirectory": ".",
  "builds": [
    {
      "src": "api/index.php",
      "use": "vercel-php@0.8.0",
      "config": { 
        "composer": true,
        "includeFiles": ["bootstrap/**", "config/**", "database/**", "routes/**", "app/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.php"
    }
  ]
}